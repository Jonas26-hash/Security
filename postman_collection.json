        {
          "name": "Validar Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/auth/validate?token={{jwt_token}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "validate"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
